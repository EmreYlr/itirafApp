    "am8-HW-SGT.text" : {
      "comment" : "Class = \"UILabel\"; text = \"Profilin, bu bağlantıların durumuna göre görüntülenecektir. Dilediğin zaman değiştirebilir ve bağlantı kurmak istediğin kişilere göre özelleştirebilirsin.\"; ObjectID = \"am8-HW-SGT\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your profile will be displayed based on the status of these connections. You can change them anytime and customize them according to the people you want to connect with."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Profilin, bu bağlantıların durumuna göre görüntülenecektir. Dilediğin zaman değiştirebilir ve bağlantı kurmak istediğin kişilere göre özelleştirebilirsin."
          }
        }
      }
    },
