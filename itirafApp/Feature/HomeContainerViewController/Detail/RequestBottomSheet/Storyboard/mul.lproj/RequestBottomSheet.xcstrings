    "XQT-6b-axF.text" : {
      "comment" : "Class = \"UILabel\"; text = \"İtirafa cevap olarak mesaj ekleyin. Lütfen hakarat içeren ifadeler kullanmayınız.\"; ObjectID = \"XQT-6b-axF\";",
