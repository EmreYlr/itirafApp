{
  "sourceLanguage" : "tr",
  "strings" : {
    "7Sy-9u-MwS.text" : {
      "comment" : "Class = \"UILabel\"; text = \"İtiraf sahibine anonim olarak bir sohbet istegi gönder. İsteğin kabul edilirse kimliğinizi veya sosyal medya hesaplarinizi daha sonra paylasabilirsin.\"; ObjectID = \"7Sy-9u-MwS\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Send an anonymous chat request to the confession owner. If your request is accepted, you can share your identity or social media accounts later."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "İtiraf sahibine anonim olarak bir sohbet istegi gönder. İsteğin kabul edilirse kimliğinizi veya sosyal medya hesaplarinizi daha sonra paylasabilirsin."
          }
        }
      }
    },
